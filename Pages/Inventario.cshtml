@page
@model Usuarios.Pages.InventarioModel
@{
    ViewData["Title"] = "ERP Ómicron - Inventario";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">Gestión de Inventario - Ómicron</h1>
        <a href="/" class="btn btn-outline-secondary">← Volver al Inicio</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Registrar / Editar Movimiento</h5>
        </div>
        <div class="card-body">
            <form method="post" class="row g-3">
                <input type="hidden" asp-for="ProductoActual.Id" />

                <div class="col-md-4">
                    <label>Código SKU:</label>
                    <input asp-for="ProductoActual.CodigoSKU" class="form-control" required />
                </div>
                <div class="col-md-8">
                    <label>Descripción del Equipo:</label>
                    <input asp-for="ProductoActual.Descripcion" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label>Categoría:</label>
                    <input asp-for="ProductoActual.Categoria" class="form-control" placeholder="Ej. Periféricos" />
                </div>
                <div class="col-md-3">
                    <label>Cantidad:</label>
                    <input type="number" asp-for="ProductoActual.Cantidad" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label>Distribuidor:</label>
                    <input asp-for="ProductoActual.Distribuidor" class="form-control" placeholder="Ej. PC'Smart" />
                </div>
                <div class="col-md-3">
                    <label>Movimiento:</label>
                    <select asp-for="ProductoActual.TipoMovimiento" class="form-select">
                        <option value="Entrada">Entrada</option>
                        <option value="Salida">Salida</option>
                    </select>
                </div>

                <div class="col-12 mt-3">
                    <button type="submit" class="btn btn-success">Guardar Registro</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>SKU</th>
                        <th>Descripción</th>
                        <th>Categoría</th>
                        <th>Cant.</th>
                        <th>Distribuidor</th>
                        <th>Movimiento</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prod in Model.ListaProductos)
                    {
                        <tr>
                            <td><strong>@prod.CodigoSKU</strong></td>
                            <td>@prod.Descripcion</td>
                            <td>@prod.Categoria</td>
                            <td>@prod.Cantidad</td>
                            <td>@prod.Distribuidor</td>
                            <td>
                                <span class="badge @(prod.TipoMovimiento == "Entrada" ? "bg-success" : "bg-danger")">
                                    @prod.TipoMovimiento
                                </span>
                            </td>
                            <td style="white-space: nowrap;">
                                <form method="get" style="display:inline-block; margin-right: 5px;">
                                    <input type="hidden" name="idEditar" value="@prod.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary">Editar</button>
                                </form>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@prod.Id" style="display:inline-block;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Seguro que deseas eliminar el SKU @prod.CodigoSKU?');">
                                        Borrar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>