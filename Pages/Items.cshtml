@page
@model Usuarios.Pages.ItemsModel
@{
    ViewData["Title"] = "Items y Drops";
}

<div class="minecraft-container mt-4">
    <h1 class="minecraft-title">Items y Drops</h1>

    <div style="text-align: left; margin-bottom: 20px;">
        <a href="/" class="mc-btn" style="text-decoration: none; padding: 10px 20px; font-size: 1.1rem; display: inline-block;">
            ← Volver al Inicio
        </a>
</div>

<div class="minecraft-container mt-4">
    <div class="minecraft-panel mt-3">
        <h3>¿Qué sueltan los Mobs?</h3>
        <p>Derrotar criaturas en Minecraft es esencial para recolectar recursos valiosos, también conocidos como "Drops".</p>
        <table class="minecraft-table mt-3">
            <thead>
                <tr>
                    <th>Mob</th>
                    <th>Item Común</th>
                    <th>Uso Principal</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Creeper</td><td>Pólvora</td><td>Craftear TNT y cohetes</td></tr>
                <tr><td>Esqueleto</td><td>Huesos / Flechas</td><td>Hacer polvo de hueso para cultivos</td></tr>
                <tr><td>Vaca</td><td>Cuero / Carne cruda</td><td>Hacer armaduras básicas y libros</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div style="display: flex; justify-content: center; gap: 30px; margin-top: 30px; flex-wrap: wrap;">

    <div style="background-color: #8b8b8b; border: 4px solid; border-color: #373737 #ffffff #ffffff #373737; padding: 20px 15px; text-align: center; width: 220px; box-shadow: inset 0 0 15px rgba(0,0,0,0.3);">
        <img src="/images/Creeper.jpg" alt="Creeper" style="width: 100%; height: 130px; object-fit: cover; border: 3px solid #555; margin-bottom: 15px;" />
        <p style="margin: 0; color: black; font-weight: bold; text-shadow: none; font-size: 1.3rem;">Creeper</p>
    </div>

    <div style="background-color: #8b8b8b; border: 4px solid; border-color: #373737 #ffffff #ffffff #373737; padding: 20px 15px; text-align: center; width: 220px; box-shadow: inset 0 0 15px rgba(0,0,0,0.3);">
        <img src="/images/esqueleto.jpg" alt="Esqueleto" style="width: 100%; height: 130px; object-fit: cover; border: 3px solid #555; margin-bottom: 15px;" />
        <p style="margin: 0; color: black; font-weight: bold; text-shadow: none; font-size: 1.3rem;">Esqueleto</p>
    </div>

    <div style="background-color: #8b8b8b; border: 4px solid; border-color: #373737 #ffffff #ffffff #373737; padding: 20px 15px; text-align: center; width: 220px; box-shadow: inset 0 0 15px rgba(0,0,0,0.3);">
        <img src="/images/Vaca.jpg" alt="Vaca" style="width: 100%; height: 130px; object-fit: cover; border: 3px solid #555; margin-bottom: 15px;" />
        <p style="margin: 0; color: black; font-weight: bold; text-shadow: none; font-size: 1.3rem;">Vaca</p>
    </div>

</div>