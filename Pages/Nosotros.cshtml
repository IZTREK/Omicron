@page
@model Usuarios.Pages.BiomasModel
@{
    ViewData["Title"] = "Sobre Ómicron";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">Nuestra Empresa</h1>
        <a href="/" class="btn btn-outline-secondary">← Volver al Inicio</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="text-primary">Más de 25 años en el mercado</h3>
            <p><strong>Ómicron</strong> es una empresa mayorista de tecnología ubicada en Aguascalientes, dedicada a ofrecer el mejor hardware para nuestros distribuidores y nuestra empresa hermana, PC'Smart.</p>
            <hr />
            <h4>Nuestra Misión (Proyecto ERP)</h4>
            <p>Debido al alto volumen de mercancía que manejamos, la eficiencia operativa es nuestro mayor activo. Este sistema ha sido implementado para eliminar los cuellos de botella manuales, asegurando la trazabilidad de cada componente desde que entra al almacén hasta que es despachado.</p>
        </div>
    </div>
</div>