@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio - Ómicron";
}

<div class="main-panel" style="text-align: center;">

    <h1 class="minecraft-title">Bienvenido al Portal Ómicron</h1>

    <p class="subtitle">
        Sistema Central de Planificación de Recursos Empresariales (ERP / CRM)
    </p>

    <br><br>

    <div style="display: flex; flex-direction: row; justify-content: center; align-items: center; gap: 50px; flex-wrap: wrap;">

        <div style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/Inventario" class="button" style="width: 250px;">
                Gestión de Inventario
            </a>
            <a href="/Nosotros" class="button" style="width: 250px;">
                Sobre la Empresa
            </a>
            <a href="/Contacto" class="button" style="width: 250px;">
                Soporte Técnico
            </a>
        </div>

        <div>
            <img src="https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" alt="Servidores Ómicron" style="border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 250px; height: auto;" />
        </div>

    </div>

</div>